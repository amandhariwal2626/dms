{
  "name": "@repo/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "db:generate": "prisma generate",
    "lint": "eslint .",
    "test": "echo \"No tests configured for database\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "prisma": "^6.11.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  }
}
