generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

/// Legal structure of the business entity
enum BusinessType {
  SOLE_PROPRIETORSHIP
  PARTNERSHIP
  LIMITED_LIABILITY_PARTNERSHIP
  PRIVATE_LIMITED
  PUBLIC_LIMITED
  ONE_PERSON_COMPANY
  NON_PROFIT
  GOVERNMENT_UNDERTAKING
  OTHER

  @@map("business_type")
}

/// Classification category of the company
enum CompanyCategory {
  MANUFACTURER
  DISTRIBUTOR
  WHOLESALER
  RETAILER
  SUPPLIER
  SERVICE_PROVIDER
  BROKER
  AGENT
  OTHER

  @@map("company_category")
}

/// Subscription plan tiers
enum SubscriptionPlan {
  FREE
  STARTER
  GROWTH
  PROFESSIONAL
  ENTERPRISE
  CUSTOM

  @@map("subscription_plan")
}

/// Current status of the subscription
enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
  TRIAL
  PAST_DUE

  @@map("subscription_status")
}

/// Lifecycle status of the company record
enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DISABLED
  ARCHIVED
  PENDING_VERIFICATION
  REJECTED

  @@map("company_status")
}

/// Supported currency codes
enum Currency {
  INR
  USD
  EUR
  GBP
  AED
  SGD
  AUD
  CAD

  @@map("currency")
}

/// Supported timezone identifiers
enum Timezone {
  UTC
  ASIA_KOLKATA
  ASIA_DUBAI
  ASIA_SINGAPORE
  AMERICA_NEW_YORK
  AMERICA_CHICAGO
  AMERICA_DENVER
  AMERICA_LOS_ANGELES
  EUROPE_LONDON
  EUROPE_BERLIN
  EUROPE_PARIS
  AUSTRALIA_SYDNEY

  @@map("timezone")
}

/// Supported interface languages
enum Language {
  EN
  HI
  GU
  MR
  TA
  TE
  KN
  BN
  ES
  FR
  AR

  @@map("language")
}

/// Biological gender of the user
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY

  @@map("gender")
}

/// Marital status of the user
enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
  PREFER_NOT_TO_SAY

  @@map("marital_status")
}

/// Preferred channel for sending communications to the user
enum PreferredCommunicationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH_NOTIFICATION
  IN_APP

  @@map("preferred_communication_channel")
}

/// Lifecycle status of a user account
enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  LOCKED
  SUSPENDED
  INACTIVE
  DELETED

  @@map("user_status")
}

/// Purpose of the email verification
enum VerificationPurpose {
  REGISTER
  LOGIN
  CHANGE_EMAIL
  RESET_PASSWORD
  INVITE

  @@map("verification_purpose")
}

/// Method of verification delivery
enum VerificationTokenType {
  OTP
  MAGIC_LINK
  EMAIL_LINK

  @@map("verification_token_type")
}

/// Current lifecycle state of a verification record
enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
  BLOCKED

  @@map("verification_status")
}

/// Type of employment contract
enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
  CONSULTANT
  PROBATION
  TRAINEE

  @@map("employment_type")
}

/// Current employment status within a company
enum EmploymentStatus {
  ACTIVE
  PROBATION
  NOTICE_PERIOD
  TERMINATED
  RESIGNED
  RETIRED
  DEPUTATION

  @@map("employment_status")
}

/// Company-specific lifecycle status of a user membership
enum CompanyUserStatus {
  INVITED
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
  LEFT

  @@map("company_user_status")
}

/// Organisational department within a company
enum Department {
  ADMIN
  HR
  FINANCE
  IT
  SALES
  MARKETING
  OPERATIONS
  PURCHASE
  WAREHOUSE
  LOGISTICS
  PRODUCTION
  QUALITY
  RND
  CUSTOMER_SUPPORT
  LEGAL
  OTHER

  @@map("department")
}

/// Strategic business unit classification
enum BusinessUnit {
  FMCG
  PHARMA
  ELECTRONICS
  AUTOMOTIVE
  AGRICULTURE
  TEXTILE
  CHEMICAL
  OTHER

  @@map("business_unit")
}

/// Operational division within a business unit
enum Division {
  DOMESTIC
  EXPORT
  WHOLESALE
  RETAIL
  ONLINE
  INSTITUTIONAL
  OTHER

  @@map("division")
}

/// Category of device used for authentication
enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  LAPTOP
  SMART_TV
  KIOSK
  OTHER

  @@map("device_type")
}

/// Software platform of the client application
enum Platform {
  WEB
  ANDROID
  IOS
  WINDOWS
  MACOS
  LINUX
  API

  @@map("platform")
}

/// Current lifecycle state of a user session
enum SessionStatus {
  ACTIVE
  EXPIRED
  LOGGED_OUT
  REVOKED
  IDLE_TIMEOUT

  @@map("session_status")
}

/// Reason why a session was terminated
enum LogoutReason {
  USER_LOGOUT
  SESSION_EXPIRED
  DEVICE_REVOKED
  ADMIN_REVOKED
  PASSWORD_CHANGED
  IDLE_TIMEOUT
  MAX_SESSIONS_REACHED
  SUSPICIOUS_ACTIVITY
  OTHER

  @@map("logout_reason")
}

/// Origin classification of a role
enum RoleType {
  SYSTEM
  DEFAULT
  CUSTOM

  @@map("role_type")
}

/// Lifecycle status of a role record
enum RoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED

  @@map("role_status")
}

/// Granular action that a permission grants
enum PermissionAction {
  VIEW
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  IMPORT
  EXPORT
  PRINT
  UPLOAD
  DOWNLOAD
  ASSIGN
  TRANSFER
  CANCEL
  RESTORE
  ARCHIVE

  @@map("permission_action")
}

/// Classification of what the permission controls
enum PermissionType {
  MENU
  SCREEN
  API
  ACTION
  FEATURE

  @@map("permission_type")
}

/// Lifecycle status of a permission record
enum PermissionStatus {
  ACTIVE
  INACTIVE

  @@map("permission_status")
}

/// HTTP methods for API-level permissions
enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
  HEAD
  OPTIONS

  @@map("http_method")
}

/// Lifecycle status of a module
enum ModuleStatus {
  ACTIVE
  INACTIVE
  DEPRECATED

  @@map("module_status")
}

/// Functional category grouping for modules
enum ModuleCategory {
  CORE
  MASTER
  TRANSACTION
  REPORTS
  CONFIGURATION
  INTEGRATION
  SETTINGS

  @@map("module_category")
}

/// Whether the permission is granted or denied
enum PermissionEffect {
  ALLOW
  DENY

  @@map("permission_effect")
}

/// How broadly a role permission applies
enum PermissionScope {
  GLOBAL
  COMPANY
  WAREHOUSE
  REGION
  ROUTE
  BEAT
  SELF
  CUSTOM

  @@map("permission_scope")
}

/// Lifecycle status of a role-permission assignment
enum RolePermissionStatus {
  ACTIVE
  INACTIVE

  @@map("role_permission_status")
}

// ──────────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────────

/// Represents one tenant in the DMS. Every entity belongs to a company.
model Company {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Primary Information ───────────────────────
  /// Auto-generated unique company code (e.g., CMP000001)
  companyCode            String   @unique @map("company_code")
  legalName              String   @map("legal_name")
  displayName            String   @map("display_name")
  businessType           BusinessType @map("business_type")
  companyCategory        CompanyCategory @map("company_category")
  gstNumber              String?  @unique @map("gst_number")
  panNumber              String?  @unique @map("pan_number")
  tanNumber              String?  @map("tan_number")
  cinNumber              String?  @map("cin_number")
  udyamRegistrationNumber String? @map("udyam_registration_number")
  fssaiNumber            String?  @map("fssai_number")
  drugLicenseNumber      String?  @map("drug_license_number")
  website                String?  @map("website")
  email                  String?  @unique @map("email")
  phone                  String?  @map("phone")
  alternatePhone         String?  @map("alternate_phone")
  logoUrl                String?  @map("logo_url")
  description            String?  @map("description")

  // ─── Business Configuration ────────────────────
  currency               Currency         @default(INR) @map("currency")
  timezone               Timezone         @default(ASIA_KOLKATA) @map("timezone")
  dateFormat             String           @default("DD/MM/YYYY") @map("date_format")
  timeFormat             String           @default("HH:mm") @map("time_format")
  countryCode            String           @default("+91") @map("country_code")
  language               Language         @default(EN) @map("language")
  financialYearStartMonth Int             @default(4) @map("financial_year_start_month")
  defaultTaxType         String?          @map("default_tax_type")
  baseCurrency           Currency         @default(INR) @map("base_currency")
  decimalPrecision       Int              @default(2) @map("decimal_precision")
  quantityPrecision      Int              @default(2) @map("quantity_precision")
  pricePrecision         Int              @default(2) @map("price_precision")
  weightPrecision        Int              @default(2) @map("weight_precision")

  // ─── Address ───────────────────────────────────
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  landmark     String?  @map("landmark")
  city         String?  @map("city")
  district     String?  @map("district")
  state        String?  @map("state")
  country      String?  @map("country")
  postalCode   String?  @map("postal_code")
  latitude     Float?   @map("latitude")
  longitude    Float?   @map("longitude")

  // ─── Subscription ──────────────────────────────
  subscriptionPlan     SubscriptionPlan   @default(FREE) @map("subscription_plan")
  subscriptionStatus   SubscriptionStatus @default(TRIAL) @map("subscription_status")
  subscriptionStartDate DateTime?         @map("subscription_start_date")
  subscriptionEndDate   DateTime?         @map("subscription_end_date")
  trialEndsAt           DateTime?         @map("trial_ends_at")
  maxUsers              Int               @default(5) @map("max_users")
  maxWarehouses         Int               @default(1) @map("max_warehouses")
  maxProducts           Int               @default(100) @map("max_products")
  maxRetailers          Int               @default(50) @map("max_retailers")
  maxDistributors       Int               @default(10) @map("max_distributors")
  maxSalesmen           Int               @default(10) @map("max_salesmen")
  maxOrdersPerMonth     Int               @default(500) @map("max_orders_per_month")
  storageLimitInGB      Int               @default(5) @map("storage_limit_in_gb")

  // ─── Company Settings ──────────────────────────
  allowNegativeInventory     Boolean @default(false) @map("allow_negative_inventory")
  enableBatchTracking        Boolean @default(false) @map("enable_batch_tracking")
  enableExpiryTracking       Boolean @default(false) @map("enable_expiry_tracking")
  enableSerialNumberTracking Boolean @default(false) @map("enable_serial_number_tracking")
  enableMultiWarehouse       Boolean @default(false) @map("enable_multi_warehouse")
  enableMultiCurrency        Boolean @default(false) @map("enable_multi_currency")
  enableRouteManagement      Boolean @default(false) @map("enable_route_management")
  enableBeatPlanning         Boolean @default(false) @map("enable_beat_planning")
  enableAttendance           Boolean @default(false) @map("enable_attendance")
  enableGeoTracking          Boolean @default(false) @map("enable_geo_tracking")
  enableSecondarySales       Boolean @default(false) @map("enable_secondary_sales")
  enablePrimarySales         Boolean @default(false) @map("enable_primary_sales")
  enablePromotions           Boolean @default(false) @map("enable_promotions")
  enableLoyaltyProgram       Boolean @default(false) @map("enable_loyalty_program")
  enablePriceList            Boolean @default(false) @map("enable_price_list")
  enableSchemeManagement     Boolean @default(false) @map("enable_scheme_management")
  enablePurchaseModule       Boolean @default(false) @map("enable_purchase_module")
  enableReturns              Boolean @default(false) @map("enable_returns")
  enableApprovals            Boolean @default(false) @map("enable_approvals")
  enableAuditLogs            Boolean @default(false) @map("enable_audit_logs")
  enableApiAccess            Boolean @default(false) @map("enable_api_access")
  enableWebhook              Boolean @default(false) @map("enable_webhook")

  // ─── Branding ──────────────────────────────────
  primaryColor   String? @map("primary_color")
  secondaryColor String? @map("secondary_color")
  faviconUrl     String? @map("favicon_url")
  emailHeaderLogo String? @map("email_header_logo")
  invoiceLogo    String? @map("invoice_logo")

  // ─── Status ────────────────────────────────────
  status           CompanyStatus @default(PENDING_VERIFICATION) @map("status")
  isActive         Boolean       @default(false) @map("is_active")
  isVerified       Boolean       @default(false) @map("is_verified")
  verificationDate DateTime?     @map("verification_date")
  verifiedBy       String?       @map("verified_by")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  companyUsers CompanyUser[]
  roles        Role[]
  // Warehouses     Warehouse[]
  // Products       Product[]
  // Retailers      Retailer[]
  // Distributors   Distributor[]
  // Salesmen       Salesman[]
  // Routes         Route[]
  // Orders         Order[]
  // Permissions    Permission[]
  // Masters        Master[]

  // ─── Indexes ───────────────────────────────────
  @@index([companyCode])
  @@index([status])
  @@index([gstNumber])
  @@index([legalName])
  @@index([displayName])
  @@index([isDeleted])
  @@index([subscriptionStatus])
  @@index([businessType])
  @@index([companyCategory])
  @@index([city])
  @@index([state])
  @@index([createdAt])

  // ─── Table Mapping ─────────────────────────────
  @@map("companies")
}

/// Stores email verification tokens and OTPs for self-onboarding and authentication flows.
/// At least one of `otp` or `token` must be present (enforced at application layer).
model EmailVerificationToken {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Identity ──────────────────────────────────
  /// Email address being verified
  email   String   @map("email")
  /// Hashed verification token (nullable — use OTP instead)
  token   String?  @map("token")
  /// One-time password (nullable — use token instead)
  otp     String?  @map("otp")

  // ─── Purpose & Type ────────────────────────────
  /// Why this verification was created
  purpose   VerificationPurpose   @map("purpose")
  /// How the verification is delivered
  tokenType VerificationTokenType @map("token_type")

  // ─── Expiry & Verification ─────────────────────
  /// When this token/OTP expires
  expiresAt    DateTime? @map("expires_at")
  /// When the user successfully verified (null if not yet verified)
  verifiedAt   DateTime? @map("verified_at")

  // ─── Attempt Tracking ──────────────────────────
  /// Number of verification attempts made
  attemptCount Int      @default(0) @map("attempt_count")
  /// Maximum allowed verification attempts before blocking
  maxAttempts  Int      @default(5) @map("max_attempts")
  /// Number of times the OTP/token was resent
  resendCount  Int      @default(0) @map("resend_count")
  /// Last time a resend occurred
  lastResendAt DateTime? @map("last_resend_at")

  // ─── Request Metadata ──────────────────────────
  /// IP address of the requester
  ipAddress String? @map("ip_address")
  /// User-Agent header from the request
  userAgent String? @map("user_agent")
  /// Unique device identifier
  deviceId  String? @map("device_id")
  /// Browser name (parsed from user-agent)
  browser   String? @map("browser")
  /// Operating system (parsed from user-agent)
  platform  String? @map("platform")

  // ─── Geo Location ──────────────────────────────
  country String? @map("country")
  state   String? @map("state")
  city    String? @map("city")

  // ─── Failure Tracking ──────────────────────────
  /// Reason for the last failure (e.g., "Invalid OTP", "Expired token")
  failureReason String? @map("failure_reason")

  // ─── Status ────────────────────────────────────
  status VerificationStatus @default(PENDING) @map("status")
  /// Whether this verification record has been consumed
  isUsed  Boolean   @default(false) @map("is_used")
  /// When the record was consumed
  usedAt  DateTime? @map("used_at")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Constraints ───────────────────────────────
  /// Only one active verification per email + purpose combination
  @@unique([email, purpose, isUsed, isDeleted])

  // ─── Indexes ───────────────────────────────────
  @@index([email])
  @@index([otp])
  @@index([token])
  @@index([purpose])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([isDeleted])

  // ─── Table Mapping ─────────────────────────────
  @@map("email_verification_tokens")
}

/// Represents a global user identity in the system.
/// A user can belong to multiple companies — company-specific data lives in UserCompany.
model User {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Identity ──────────────────────────────────
  /// Primary email address used for login and communication
  email            String   @unique @map("email")
  /// Case-folded copy of email for duplicate checking
  normalizedEmail  String   @unique @map("normalized_email")
  /// Unique login username
  username         String   @unique @map("username")
  /// Case-folded copy of username for duplicate checking
  normalizedUsername String @unique @map("normalized_username")
  /// Primary mobile contact number
  mobileNumber           String? @unique @map("mobile_number")
  /// Secondary mobile contact number
  alternateMobileNumber  String? @map("alternate_mobile_number")

  // ─── Personal Information ──────────────────────
  firstName       String         @map("first_name")
  middleName      String?        @map("middle_name")
  lastName        String?        @map("last_name")
  displayName     String?        @map("display_name")
  profilePhotoUrl String?        @map("profile_photo_url")
  gender          Gender?        @map("gender")
  dateOfBirth     DateTime?      @map("date_of_birth")
  bloodGroup      String?        @map("blood_group")
  maritalStatus   MaritalStatus? @map("marital_status")
  nationality     String?        @map("nationality")
  /// Preferred interface language
  preferredLanguage Language @default(EN) @map("preferred_language")
  /// User's local timezone
  timezone         Timezone @default(ASIA_KOLKATA) @map("timezone")

  // ─── Authentication ────────────────────────────
  /// Bcrypt-hashed password
  passwordHash        String    @map("password_hash")
  /// Timestamp of last password change (for token invalidation)
  passwordChangedAt   DateTime? @map("password_changed_at")
  emailVerified       Boolean   @default(false) @map("email_verified")
  emailVerifiedAt     DateTime? @map("email_verified_at")
  mobileVerified      Boolean   @default(false) @map("mobile_verified")
  mobileVerifiedAt    DateTime? @map("mobile_verified_at")
  twoFactorEnabled    Boolean   @default(false) @map("two_factor_enabled")
  /// Encrypted TOTP secret for 2FA
  twoFactorSecret     String?   @map("two_factor_secret")
  /// Forces password change on next login (e.g., admin reset)
  passwordResetRequired Boolean @default(false) @map("password_reset_required")
  /// Forces password change (used during first login after invite)
  forcePasswordChange   Boolean @default(false) @map("force_password_change")
  /// Incremented on password change / logout-all to invalidate all sessions
  refreshTokenVersion   Int     @default(0) @map("refresh_token_version")
  /// Random unique string changed on every authentication event
  securityStamp         String? @map("security_stamp")

  // ─── Login Tracking ────────────────────────────
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip")
  lastLoginUserAgent  String?   @map("last_login_user_agent")
  lastLoginDevice     String?   @map("last_login_device")
  /// Consecutive failed login attempts
  failedLoginAttempts Int      @default(0) @map("failed_login_attempts")
  /// Account is locked until this timestamp
  lockUntil           DateTime? @map("lock_until")
  lastPasswordResetAt DateTime? @map("last_password_reset_at")

  // ─── Status ────────────────────────────────────
  status   UserStatus @default(PENDING_VERIFICATION) @map("status")
  isActive Boolean    @default(false) @map("is_active")

  // ─── Communication ─────────────────────────────
  preferredCommunicationChannel PreferredCommunicationChannel @default(EMAIL) @map("preferred_communication_channel")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  companyUsers CompanyUser[]
  sessions     Session[]
  // UserRole                 UserRole[]
  // PasswordResetToken       PasswordResetToken[]
  // EmailVerificationToken   EmailVerificationToken[]
  // AuditLog                 AuditLog[]
  // Notification             Notification[]
  // FileStorage              FileStorage[]

  // ─── Indexes ───────────────────────────────────
  @@index([email])
  @@index([normalizedEmail])
  @@index([username])
  @@index([normalizedUsername])
  @@index([mobileNumber])
  @@index([status])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([lastLoginAt])

  // ─── Table Mapping ─────────────────────────────
  @@map("users")
}

/// Associates a user with a company and stores all company-specific employee information.
/// This is not a simple junction table — it holds role, reporting, and employment data.
model CompanyUser {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Foreign Keys ──────────────────────────────
  /// Reference to the company
  companyId String @map("company_id")
  /// Reference to the global user
  userId    String @map("user_id")

  // ─── Employee Information ──────────────────────
  /// Unique employee code within the company (e.g., EMP000001)
  employeeCode         String           @map("employee_code")
  /// Company-specific email address
  officialEmail        String           @map("official_email")
  officialMobileNumber String?          @map("official_mobile_number")
  designation          String?          @map("designation")
  department           Department?      @map("department")
  jobTitle             String?          @map("job_title")
  employmentType       EmploymentType?  @map("employment_type")
  employmentStatus     EmploymentStatus? @map("employment_status")
  joiningDate          DateTime?        @map("joining_date")
  confirmationDate     DateTime?        @map("confirmation_date")
  relievingDate        DateTime?        @map("relieving_date")
  experienceInYears    Int?             @map("experience_in_years")

  // ─── Reporting Hierarchy ───────────────────────
  /// Self-referencing FK to another CompanyUser record (the manager)
  reportingManagerId   String?  @map("reporting_manager_id")
  /// Whether this user is a reporting manager for any subordinates
  isReportingManager   Boolean  @default(false) @map("is_reporting_manager")

  // ─── Company Access ────────────────────────────
  /// The user's primary company (used for multi-tenant context)
  isPrimaryCompany Boolean @default(false) @map("is_primary_company")
  /// Auto-selected on login
  isDefaultCompany Boolean @default(false) @map("is_default_company")
  /// Whether the user can switch to this company from another
  canSwitchCompany Boolean @default(true) @map("can_switch_company")

  // ─── Default Assignments ───────────────────────
  defaultWarehouseId    String? @map("default_warehouse_id")
  defaultRouteId        String? @map("default_route_id")
  defaultBeatId         String? @map("default_beat_id")
  defaultSalesRegionId  String? @map("default_sales_region_id")
  defaultPriceListId    String? @map("default_price_list_id")

  // ─── Work Information ──────────────────────────
  workLocation String?       @map("work_location")
  costCenter   String?       @map("cost_center")
  businessUnit BusinessUnit? @map("business_unit")
  division     Division?     @map("division")
  salesRegion  String?       @map("sales_region")
  zone         String?       @map("zone")
  territory    String?       @map("territory")
  cluster      String?       @map("cluster")

  // ─── Permissions ───────────────────────────────
  canApproveOrders   Boolean  @default(false) @map("can_approve_orders")
  canApproveReturns  Boolean  @default(false) @map("can_approve_returns")
  canApprovePurchases Boolean @default(false) @map("can_approve_purchases")
  canApprovePayments Boolean  @default(false) @map("can_approve_payments")
  /// Maximum monetary value this user can approve
  approvalLimit      Decimal? @map("approval_limit")

  // ─── Login Status (Company-specific) ───────────
  lastCompanyLoginAt     DateTime? @map("last_company_login_at")
  lastCompanyLoginIp     String?   @map("last_company_login_ip")
  lastCompanyLoginDevice String?   @map("last_company_login_device")

  // ─── Invitation ────────────────────────────────
  invitedBy             String?   @map("invited_by")
  invitedAt             DateTime? @map("invited_at")
  acceptedInvitationAt  DateTime? @map("accepted_invitation_at")

  // ─── Status ────────────────────────────────────
  status   CompanyUserStatus @default(INVITED) @map("status")
  isActive Boolean           @default(false)  @map("is_active")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  company          Company      @relation(fields: [companyId], references: [id])
  user             User         @relation(fields: [userId], references: [id])
  /// Self-relation: the manager of this user within the company
  reportingManager CompanyUser? @relation("ReportingHierarchy", fields: [reportingManagerId], references: [id])
  /// Inverse self-relation: subordinates reporting to this user
  subordinates     CompanyUser[] @relation("ReportingHierarchy")

  // UserRole              UserRole[]
  // Attendance            Attendance[]
  // Leave                 Leave[]
  // WarehouseAssignment   WarehouseAssignment[]
  // BeatAssignment        BeatAssignment[]
  // RouteAssignment       RouteAssignment[]
  // SalesOrder            SalesOrder[]
  // ApprovalHistory       ApprovalHistory[]
  // Notification          Notification[]
  // AuditLog              AuditLog[]

  // ─── Constraints ───────────────────────────────
  /// A user can belong only once to a company
  @@unique([companyId, userId])
  /// Employee code must be unique within a company
  @@unique([companyId, employeeCode])
  /// Official email must be unique within a company
  @@unique([companyId, officialEmail])

  // ─── Indexes ───────────────────────────────────
  @@index([companyId])
  @@index([userId])
  @@index([employeeCode])
  @@index([officialEmail])
  @@index([designation])
  @@index([department])
  @@index([status])
  @@index([reportingManagerId])
  @@index([isDeleted])
  @@index([joiningDate])

  // ─── Table Mapping ─────────────────────────────
  @@map("company_users")
}

/// Represents an authenticated user session across devices.
/// Sessions are independent of company context — company selection happens post-auth.
model Session {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Foreign Keys ──────────────────────────────
  /// Reference to the authenticated user
  userId String @map("user_id")

  // ─── Authentication ────────────────────────────
  /// Unique identifier of the access JWT (for revocation)
  accessTokenId      String  @unique @map("access_token_id")
  /// Hashed refresh token stored server-side
  refreshTokenHash   String  @map("refresh_token_hash")
  /// Snapshot of the user's refreshTokenVersion at session creation
  refreshTokenVersion Int    @default(0) @map("refresh_token_version")
  /// Unique JWT ID (jti claim) for this session
  jwtId              String  @unique @map("jwt_id")

  // ─── Device Information ────────────────────────
  deviceId        String?    @map("device_id")
  deviceName      String?    @map("device_name")
  deviceType      DeviceType? @map("device_type")
  operatingSystem String?    @map("operating_system")
  osVersion       String?    @map("os_version")
  browser         String?    @map("browser")
  browserVersion  String?    @map("browser_version")
  appVersion      String?    @map("app_version")
  platform        Platform?  @map("platform")

  // ─── Network Information ───────────────────────
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  country   String? @map("country")
  state     String? @map("state")
  city      String? @map("city")
  latitude  Float?  @map("latitude")
  longitude Float?  @map("longitude")
  /// Timezone of the client at login time
  timezone  String? @map("timezone")

  // ─── Login Information ─────────────────────────
  loginAt        DateTime      @default(now()) @map("login_at")
  lastActivityAt DateTime      @default(now()) @map("last_activity_at")
  expiresAt      DateTime?     @map("expires_at")
  loggedOutAt    DateTime?     @map("logged_out_at")
  logoutReason   LogoutReason? @map("logout_reason")

  // ─── Security ──────────────────────────────────
  isCurrentSession Boolean @default(false) @map("is_current_session")
  isTrustedDevice  Boolean @default(false) @map("is_trusted_device")
  rememberMe       Boolean @default(false) @map("remember_me")
  mfaVerified      Boolean @default(false) @map("mfa_verified")
  /// Numeric risk score (0–100) from security analysis
  riskScore        Int?    @map("risk_score")
  isRevoked        Boolean @default(false) @map("is_revoked")
  revokedAt        DateTime? @map("revoked_at")
  revokedBy        String?   @map("revoked_by")
  revocationReason String?   @map("revocation_reason")

  // ─── Status ────────────────────────────────────
  status SessionStatus @default(ACTIVE) @map("status")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  user User @relation(fields: [userId], references: [id])

  // AuditLog       AuditLog[]
  // LoginHistory   LoginHistory[]
  // Notification   Notification[]

  // ─── Indexes ───────────────────────────────────
  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@index([expiresAt])
  @@index([loginAt])
  @@index([lastActivityAt])
  @@index([isRevoked])
  @@index([isDeleted])
  @@index([ipAddress])

  // ─── Table Mapping ─────────────────────────────
  @@map("sessions")
}

/// Company-specific role for RBAC. Every company has its own set of roles.
/// Supports SYSTEM (seeded), DEFAULT (auto-created), and CUSTOM (user-created) types.
model Role {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Foreign Keys ──────────────────────────────
  /// Reference to the owning company
  companyId String @map("company_id")

  // ─── Basic Information ─────────────────────────
  /// Human-readable role name (e.g., "Sales Manager")
  name String @map("name")
  /// Unique code for programmatic reference (e.g., "SALES_MANAGER")
  code        String  @map("code")
  displayName String? @map("display_name")
  description String? @map("description")

  // ─── Role Type ─────────────────────────────────
  roleType RoleType @default(CUSTOM) @map("role_type")

  // ─── Hierarchy ─────────────────────────────────
  /// Self-referencing FK for role hierarchy (e.g., Manager > Executive)
  parentRoleId    String? @map("parent_role_id")
  /// Numeric level in the role hierarchy tree
  hierarchyLevel  Int     @default(0) @map("hierarchy_level")
  /// Display / sorting priority (lower = higher)
  priority        Int     @default(0) @map("priority")

  // ─── Permissions ───────────────────────────────
  /// Whether this is a system-protected role
  isSystemRole  Boolean @default(false) @map("is_system_role")
  /// Whether the role name/code can be modified
  isEditable    Boolean @default(true) @map("is_editable")
  /// Whether the role can be deleted
  isDeletable   Boolean @default(true) @map("is_deletable")
  /// Whether the role can be assigned to users
  isAssignable  Boolean @default(true) @map("is_assignable")

  // ─── Dashboard ─────────────────────────────────
  /// Default landing page route for users with this role
  defaultLandingPage String? @map("default_landing_page")
  /// Default module to show on login
  defaultModule      String? @map("default_module")

  // ─── Status ────────────────────────────────────
  status   RoleStatus @default(ACTIVE) @map("status")
  isActive Boolean    @default(true)  @map("is_active")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  company     Company @relation(fields: [companyId], references: [id])
  /// Self-relation: parent role in the hierarchy
  parentRole  Role?   @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  /// Inverse self-relation: child roles beneath this one
  childRoles  Role[]  @relation("RoleHierarchy")

  rolePermissions RolePermission[]
  // UserRole      UserRole[]

  // ─── Constraints ───────────────────────────────
  /// Role name must be unique within a company
  @@unique([companyId, name])
  /// Role code must be unique within a company
  @@unique([companyId, code])

  // ─── Indexes ───────────────────────────────────
  @@index([companyId])
  @@index([name])
  @@index([code])
  @@index([status])
  @@index([roleType])
  @@index([parentRoleId])
  @@index([isDeleted])

  // ─── Table Mapping ─────────────────────────────
  @@map("roles")
}

/// Global permission catalog for the entire DMS.
/// Permissions are not company-specific — they define the full set of possible actions
/// across all modules. Roles are then mapped to permissions via RolePermission.
model Permission {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Module Information ────────────────────────
  /// Top-level module name (e.g., "Products", "Sales Order")
  module    String @map("module")
  /// Submodule within the parent module (e.g., "Categories" under "Products")
  subModule String? @map("sub_module")
  /// Specific feature or screen within the submodule
  feature   String? @map("feature")
  /// Individual UI screen identifier
  screen    String? @map("screen")

  // ─── Permission Information ────────────────────
  /// Human-readable unique permission name
  name        String  @unique @map("name")
  /// Display label for UI (e.g., "Create Product")
  displayName String? @map("display_name")
  /// Unique programmatic code (e.g., "PRODUCT_CREATE")
  code        String  @unique @map("code")
  /// Purpose of this permission
  description String? @map("description")

  // ─── Action ────────────────────────────────────
  /// The CRUD / action verb this permission represents
  action PermissionAction @map("action")

  // ─── Resource ──────────────────────────────────
  /// Type of resource being controlled (e.g., "Product", "Order")
  resourceType String? @map("resource_type")
  /// Name of the resource
  resourceName String? @map("resource_name")
  /// API endpoint path (for API-type permissions)
  apiEndpoint  String?  @map("api_endpoint")
  /// HTTP method for the API endpoint
  httpMethod   HttpMethod? @map("http_method")
  /// Frontend route path (for menu/screen permissions)
  frontendRoute String? @map("frontend_route")
  /// Unique key for menu identification
  menuKey       String? @map("menu_key")
  /// Icon class or identifier for UI display
  icon          String? @map("icon")
  /// Sort order for displaying in menus
  displayOrder  Int?    @map("display_order")

  // ─── UI Configuration ──────────────────────────
  showInMenu    Boolean @default(true)  @map("show_in_menu")
  showInSidebar Boolean @default(true)  @map("show_in_sidebar")
  showInMobile  Boolean @default(true)  @map("show_in_mobile")
  /// Whether this permission should be hidden from the UI
  isHidden      Boolean @default(false) @map("is_hidden")

  // ─── Permission Type ───────────────────────────
  permissionType PermissionType @default(FEATURE) @map("permission_type")

  // ─── Flags ─────────────────────────────────────
  /// System permissions cannot be modified or deleted
  isSystemPermission Boolean @default(false) @map("is_system_permission")
  /// Whether the permission metadata can be edited
  isEditable   Boolean @default(true) @map("is_editable")
  /// Deprecated permissions are hidden but kept for historical references
  isDeprecated Boolean @default(false) @map("is_deprecated")

  // ─── Status ────────────────────────────────────
  status   PermissionStatus @default(ACTIVE) @map("status")
  isActive Boolean           @default(true) @map("is_active")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  rolePermissions RolePermission[]

  // ─── Indexes ───────────────────────────────────
  @@index([module])
  @@index([subModule])
  @@index([feature])
  @@index([action])
  @@index([permissionType])
  @@index([status])
  @@index([code])
  @@index([isDeleted])

  // ─── Table Mapping ─────────────────────────────
  @@map("permissions")
}

/// Represents a functional area of the DMS used for sidebar navigation, permission
/// grouping, feature management, and licensing.
model Module {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Basic Information ─────────────────────────
  /// Human-readable module name (e.g., "Product Master")
  name String @unique @map("name")
  /// Unique programmatic code (e.g., "PRODUCT_MASTER")
  code        String  @unique @map("code")
  /// UI display label
  displayName String? @map("display_name")
  /// Purpose of this module
  description String? @map("description")

  // ─── Hierarchy ─────────────────────────────────
  /// Self-referencing FK for parent-child module nesting
  parentModuleId String? @map("parent_module_id")
  /// Depth level in the module tree (0 = root)
  level         Int     @default(0) @map("level")
  /// Sort order for UI rendering
  displayOrder  Int     @default(0) @map("display_order")

  // ─── Navigation ────────────────────────────────
  /// Frontend route path
  route   String? @map("route")
  /// Icon identifier for sidebar / navbar
  icon    String? @map("icon")
  /// Unique key for programmatic menu identification
  menuKey String? @map("menu_key")
  /// Badge / notification count flag
  badge   String? @map("badge")

  // ─── Visibility ────────────────────────────────
  showInSidebar Boolean @default(true) @map("show_in_sidebar")
  showInNavbar  Boolean @default(true) @map("show_in_navbar")
  showInMobile  Boolean @default(true) @map("show_in_mobile")
  showInSettings Boolean @default(true) @map("show_in_settings")

  // ─── Feature Flags ─────────────────────────────
  /// Module is essential for the system to function
  isCoreModule         Boolean @default(false) @map("is_core_module")
  /// Module is part of the system (non-removable)
  isSystemModule       Boolean @default(false) @map("is_system_module")
  /// Module requires a license to enable
  isLicensable         Boolean @default(false) @map("is_licensable")
  /// Module is enabled for all companies by default
  isEnabledByDefault   Boolean @default(true)  @map("is_enabled_by_default")
  /// Module requires a paid subscription tier
  requiresSubscription Boolean @default(false) @map("requires_subscription")
  /// Key used to check subscription feature access
  subscriptionFeatureKey String? @map("subscription_feature_key")

  // ─── UI ────────────────────────────────────────
  /// Theme colour for the module icon / badge
  color     String?         @map("color")
  /// Functional grouping category
  category  ModuleCategory? @map("category")
  /// Logical group name for collapsible sidebar sections
  groupName String?         @map("group_name")

  // ─── Status ────────────────────────────────────
  status   ModuleStatus @default(ACTIVE) @map("status")
  isActive Boolean      @default(true)  @map("is_active")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  /// Parent module in the hierarchy
  parentModule Module? @relation("ModuleHierarchy", fields: [parentModuleId], references: [id])
  /// Child modules nested under this one
  childModules Module[] @relation("ModuleHierarchy")

  rolePermissions RolePermission[]
  // Permission    Permission[]

  // ─── Indexes ───────────────────────────────────
  @@index([name])
  @@index([code])
  @@index([displayOrder])
  @@index([parentModuleId])
  @@index([status])
  @@index([isDeleted])

  // ─── Table Mapping ─────────────────────────────
  @@map("modules")
}

/// Maps a role to a permission with support for allow/deny, scope, conditions,
/// field-level security, and time-bound validity.
model RolePermission {
  // ─── Primary Key ───────────────────────────────
  id String @id @default(uuid()) @map("id")

  // ─── Foreign Keys ──────────────────────────────
  /// Reference to the role
  roleId String @map("role_id")
  /// Reference to the global permission
  permissionId String @map("permission_id")
  /// Reference to the module (denormalised for query performance)
  moduleId String @map("module_id")

  // ─── Access ────────────────────────────────────
  /// Whether this entry grants or denies the permission
  effect PermissionEffect @default(ALLOW) @map("effect")

  // ─── Scope ─────────────────────────────────────
  /// How broadly this assignment applies
  scope PermissionScope @default(GLOBAL) @map("scope")

  // ─── Conditions ────────────────────────────────
  /// Dynamic expression evaluated at runtime (e.g., "department == 'SALES'")
  conditionExpression String? @map("condition_expression")
  /// Specific fields the permission applies to (for field-level security)
  fieldRestrictions Json? @map("field_restrictions")
  /// Row-level filter predicate (for row-level security)
  rowFilter Json? @map("row_filter")

  // ─── Validity ──────────────────────────────────
  /// When this permission assignment becomes active
  effectiveFrom DateTime? @map("effective_from")
  /// When this permission assignment expires
  effectiveTo   DateTime? @map("effective_to")

  // ─── Flags ─────────────────────────────────────
  /// Whether this permission was inherited from a parent role
  isInherited      Boolean @default(false) @map("is_inherited")
  /// Whether this was assigned automatically by the system
  isSystemAssigned Boolean @default(false) @map("is_system_assigned")

  // ─── Status ────────────────────────────────────
  status   RolePermissionStatus @default(ACTIVE) @map("status")
  isActive Boolean              @default(true)  @map("is_active")

  // ─── Metadata ──────────────────────────────────
  /// Flexible JSON field for extensible metadata
  metadata Json? @map("metadata")

  // ─── Audit Fields ──────────────────────────────
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  createdBy String?  @map("created_by")
  updatedBy String?  @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?  @map("deleted_by")
  isDeleted Boolean  @default(false) @map("is_deleted")

  // ─── Optimistic Locking ────────────────────────
  /// Incremented on every update for optimistic concurrency control
  version Int @default(1) @map("version")

  // ─── Relations ─────────────────────────────────
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  module     Module     @relation(fields: [moduleId], references: [id])

  // ─── Constraints ───────────────────────────────
  /// A role cannot have duplicate permissions
  @@unique([roleId, permissionId])

  // ─── Indexes ───────────────────────────────────
  @@index([roleId])
  @@index([permissionId])
  @@index([moduleId])
  @@index([effect])
  @@index([scope])
  @@index([status])
  @@index([isDeleted])

  // ─── Table Mapping ─────────────────────────────
  @@map("role_permissions")
}
